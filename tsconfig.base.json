{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "sourceMap": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@glamandi/api/*": ["apps/api/src/*"],
      "@glamandi/worker/*": ["apps/worker/src/*"],
      "@glamandi/types": ["packages/types/src/index.ts"],
      "@glamandi/types/*": ["packages/types/src/*"],
      "@glamandi/contracts": ["packages/contracts/src/index.ts"],
      "@glamandi/contracts/*": ["packages/contracts/src/*"],
      "@glamandi/sync": ["packages/sync/src/index.ts"],
      "@glamandi/sync/*": ["packages/sync/src/*"],
      "@glamandi/utils": ["packages/utils/src/index.ts"],
      "@glamandi/utils/*": ["packages/utils/src/*"],
      "@glamandi/config": ["packages/config/src/index.ts"],
      "@glamandi/config/*": ["packages/config/src/*"],
      "@glamandi/ui": ["packages/ui/src/index.ts"],
      "@glamandi/ui/*": ["packages/ui/src/*"]
    }
  }
}
