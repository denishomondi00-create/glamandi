{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "module": "commonjs",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@glamandi/types/*": ["../../packages/types/src/*"],
      "@glamandi/contracts/*": ["../../packages/contracts/src/*"],
      "@glamandi/contracts": ["../../packages/contracts/src/index.ts"]
    }
  },
  "references": [
    { "path": "../../packages/contracts" },
    { "path": "../../packages/types" }
  ],
  "include": ["src/**/*.ts"]
}
